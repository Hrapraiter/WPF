<Window x:Class="WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF"
        mc:Ignorable="d"
        Title="Inroduction to WPF PV_522" Height="450" Width="800">
    <Grid>
        <Grid.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF0E0E0E"/>
                <GradientStop Color="#FF0E0E0E"/>
                <GradientStop Color="#FFDDDDDD"/>
                <GradientStop Color="#FF989898"/>
                <GradientStop Color="#FF3F3F3F"/>
                <GradientStop Color="#FF0B0B0B"/>
                <GradientStop Color="Black" Offset="0"/>
                <GradientStop Color="#FF3C3C3C" Offset="1"/>
                <GradientStop Color="#FFC7C7C7" Offset="0"/>
                <GradientStop Color="White"/>
                <GradientStop Color="#FF969696"/>
            </LinearGradientBrush>
        </Grid.Background>
        <Button x:Name="btnStart"
                Content="Конопка"
                HorizontalAlignment="Center"
                Margin="0,138,0,0"
                VerticalAlignment="Top"
                Height="79"
                Width="244"
                FontSize="36"
                FontFamily="Arial Black"
                Click="Button_Click"
                >
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FF676767"/>
                    <GradientStop Color="#FF656464" Offset="1"/>
                    <GradientStop Color="#FFB5B5B5" Offset="0.491"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

    </Grid>
</Window>
